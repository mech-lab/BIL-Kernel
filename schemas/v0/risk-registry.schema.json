{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "RiskRegistryDocument",
  "type": "object",
  "required": [
    "risks",
    "schema_version"
  ],
  "properties": {
    "risks": {
      "type": "array",
      "items": {
        "$ref": "#/definitions/RiskRecord"
      }
    },
    "schema_version": {
      "type": "string"
    }
  },
  "definitions": {
    "InstitutionalProfileSection": {
      "type": "string",
      "enum": [
        "banking",
        "insurance",
        "legal_governance",
        "ai_assurance"
      ]
    },
    "RiskRecord": {
      "type": "object",
      "required": [
        "category",
        "description",
        "linked_control_ids",
        "linked_profile_sections",
        "owner",
        "risk_id",
        "severity",
        "status",
        "title"
      ],
      "properties": {
        "category": {
          "type": "string"
        },
        "description": {
          "type": "string"
        },
        "linked_control_ids": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "linked_profile_sections": {
          "type": "array",
          "items": {
            "$ref": "#/definitions/InstitutionalProfileSection"
          }
        },
        "owner": {
          "type": "string"
        },
        "risk_id": {
          "type": "string"
        },
        "severity": {
          "type": "string"
        },
        "status": {
          "type": "string"
        },
        "title": {
          "type": "string"
        }
      }
    }
  }
}
