{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "BundleDescriptor",
  "type": "object",
  "required": [
    "bundle_id",
    "bundle_kind",
    "manifest_path",
    "merkle_path",
    "payload_paths",
    "profile_version",
    "schema_version"
  ],
  "properties": {
    "bundle_id": {
      "type": "string"
    },
    "bundle_kind": {
      "$ref": "#/definitions/BundleKind"
    },
    "institutional_kind": {
      "type": [
        "string",
        "null"
      ]
    },
    "institutional_profile_version": {
      "type": [
        "string",
        "null"
      ]
    },
    "manifest_path": {
      "type": "string"
    },
    "merkle_path": {
      "type": "string"
    },
    "payload_paths": {
      "$ref": "#/definitions/BundlePayloadPaths"
    },
    "profile_version": {
      "type": "string"
    },
    "schema_version": {
      "type": "string"
    }
  },
  "definitions": {
    "BundleKind": {
      "type": "string",
      "enum": [
        "axle-evidence"
      ]
    },
    "BundlePayloadPaths": {
      "type": "object",
      "required": [
        "axle"
      ],
      "properties": {
        "axle": {
          "type": "string"
        },
        "controls": {
          "type": [
            "string",
            "null"
          ]
        },
        "institutional": {
          "type": [
            "string",
            "null"
          ]
        },
        "risk": {
          "type": [
            "string",
            "null"
          ]
        }
      }
    }
  }
}
